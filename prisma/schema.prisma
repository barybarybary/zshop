// ============================================================
// ZCode Shop - 海外版拼多多独立站 数据库模型
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// 用户系统
// ============================================================

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          String    @default("USER") // USER, ADMIN
  referralCode  String    @unique @default(uuid())
  referredBy    String?   // 被谁推荐
  points        Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  addresses     Address[]
  orders        Order[]
  reviews       Review[]
  groupBuys     GroupBuy[]
  groupBuyParts GroupBuyParticipant[]
  bargains      Bargain[]
  bargainParts  BargainParticipant[]
  userCoupons   UserCoupon[]
  referrals     Referral[]       @relation("ReferralReferrer")
  referred      Referral[]       @relation("ReferralReferred")
  cart          Cart?
}

// NextAuth.js 所需表
model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================
// 地址
// ============================================================

model Address {
  id        String  @id @default(uuid())
  userId    String
  name      String
  phone     String
  street    String
  city      String
  state     String
  zipCode   String
  country   String  @default("US")
  isDefault Boolean @default(false)

  user  User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]
}

// ============================================================
// 商品系统
// ============================================================

model Category {
  id       String     @id @default(uuid())
  name     String
  slug     String     @unique
  image    String?
  parentId String?
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]
}

model Product {
  id               String   @id @default(uuid())
  name             String
  slug             String   @unique
  description      String
  price            Float    // 原价 (USD)
  compareAtPrice   Float?   // 划线价
  costPrice        Float?   // 成本价
  categoryId       String?
  inventory        Int      @default(0)
  status           String   @default("ACTIVE") // ACTIVE, DRAFT, ARCHIVED
  isGroupBuy       Boolean  @default(false)   // 是否支持拼团
  isBargain        Boolean  @default(false)   // 是否支持砍价
  groupBuyMinPeople Int     @default(2)       // 最小成团人数
  groupBuyExpireHours Int   @default(24)      // 拼团过期时间(小时)
  bargainMinPrice  Float?                     // 砍价最低价
  bargainMaxReduction Float?                  // 最大砍价金额
  sales            Int      @default(0)
  views            Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  category   Category?        @relation(fields: [categoryId], references: [id])
  images     ProductImage[]
  variants   ProductVariant[]
  reviews    Review[]
  orderItems OrderItem[]
  groupBuys  GroupBuy[]
  bargains   Bargain[]
  cartItems  CartItem[]
}

model ProductImage {
  id        String  @id @default(uuid())
  productId String
  url       String
  alt       String?
  order     Int     @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductVariant {
  id        String @id @default(uuid())
  productId String
  name      String // e.g. "Color", "Size"
  value     String // e.g. "Red", "XL"
  price     Float? // 额外价格 (可为负数)
  inventory Int    @default(0)

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems  CartItem[]
  orderItems OrderItem[]
}

model Review {
  id        String   @id @default(uuid())
  productId String
  userId    String
  rating    Int      // 1-5
  comment   String?
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================================
// 购物车
// ============================================================

model Cart {
  id        String    @id @default(uuid())
  userId    String?   @unique
  sessionId String?   @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user  User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]
}

model CartItem {
  id        String @id @default(uuid())
  cartId    String
  productId String
  variantId String?
  quantity  Int    @default(1)

  cart    Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id])
}

// ============================================================
// 订单
// ============================================================

model Order {
  id              String   @id @default(uuid())
  userId          String
  addressId       String?
  orderNumber     String   @unique
  status          String   @default("PENDING") // PENDING, PAID, SHIPPED, DELIVERED, CANCELLED, REFUNDED
  subtotal        Float
  shipping        Float    @default(0)
  tax             Float    @default(0)
  discount        Float    @default(0)
  total           Float
  couponId        String?
  paymentIntentId String?
  // 关联拼团或砍价
  groupBuyId      String?
  bargainId       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user     User        @relation(fields: [userId], references: [id])
  address  Address?    @relation(fields: [addressId], references: [id])
  items    OrderItem[]
  groupBuy GroupBuy?   @relation(fields: [groupBuyId], references: [id])
  bargain  Bargain?    @relation(fields: [bargainId], references: [id])
}

model OrderItem {
  id        String @id @default(uuid())
  orderId   String
  productId String
  variantId String?
  name      String
  price     Float
  quantity  Int
  image     String?

  order   Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product          @relation(fields: [productId], references: [id])
  variant ProductVariant?  @relation(fields: [variantId], references: [id])
}

// ============================================================
// 拼团 (Group Buy) ⭐
// ============================================================

model GroupBuy {
  id            String   @id @default(uuid())
  productId     String
  initiatorId   String   // 发起人
  status        String   @default("OPEN") // OPEN, COMPLETED, EXPIRED, CANCELLED
  minPeople     Int      @default(2)
  currentPeople Int      @default(1)
  groupPrice    Float    // 拼团价
  expireAt      DateTime
  createdAt     DateTime @default(now())

  product      Product                @relation(fields: [productId], references: [id])
  initiator    User                   @relation(fields: [initiatorId], references: [id])
  participants GroupBuyParticipant[]
  orders       Order[]
}

model GroupBuyParticipant {
  id          String   @id @default(uuid())
  groupBuyId  String
  userId      String
  orderId     String?
  isInitiator Boolean  @default(false)
  createdAt   DateTime @default(now())

  groupBuy GroupBuy @relation(fields: [groupBuyId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])
}

// ============================================================
// 砍价 (Bargain) ⭐
// ============================================================

model Bargain {
  id            String   @id @default(uuid())
  productId     String
  userId        String   // 发起人
  originalPrice Float    // 原价
  targetPrice   Float    // 目标价（砍到底价）
  currentPrice  Float    // 当前价格
  status        String   @default("ACTIVE") // ACTIVE, SUCCESS, EXPIRED
  expireAt      DateTime
  createdAt     DateTime @default(now())

  product      Product               @relation(fields: [productId], references: [id])
  user         User                  @relation(fields: [userId], references: [id])
  participants BargainParticipant[]
  orders       Order[]
}

model BargainParticipant {
  id            String   @id @default(uuid())
  bargainId     String
  userId        String
  reducedAmount Float    // 砍掉多少钱
  createdAt     DateTime @default(now())

  bargain Bargain @relation(fields: [bargainId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])
}

// ============================================================
// 优惠券
// ============================================================

model Coupon {
  id           String   @id @default(uuid())
  code         String   @unique
  type         String   // PERCENTAGE, FIXED, FREE_SHIPPING
  value        Float    // 折扣百分比(10=10%) 或 固定金额
  minPurchase  Float?   // 最低消费金额
  maxDiscount  Float?   // 最大折扣金额(百分比券用)
  usageLimit   Int      @default(0) // 0=无限制
  usedCount    Int      @default(0)
  startsAt     DateTime?
  expiresAt    DateTime?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  userCoupons UserCoupon[]
}

model UserCoupon {
  id       String    @id @default(uuid())
  userId   String
  couponId String
  isUsed   Boolean   @default(false)
  usedAt   DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)

  @@unique([userId, couponId])
}

// ============================================================
// 推荐系统
// ============================================================

model Referral {
  id          String   @id @default(uuid())
  referrerId  String   // 推荐人
  referredId  String   // 被推荐人
  rewardGiven Boolean  @default(false)
  createdAt   DateTime @default(now())

  referrer User @relation("ReferralReferrer", fields: [referrerId], references: [id])
  referred User @relation("ReferralReferred", fields: [referredId], references: [id])
}
